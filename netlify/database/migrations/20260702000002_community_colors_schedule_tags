-- Community 2-way color palette (primary + secondary) stored ON the community so
-- the branding is unified everywhere a community appears (chat, tournaments,
-- schedules). Plus a many-to-many link between registration schedules and
-- communities, mirroring the existing tournament_communities pattern.
-- All additive + IF NOT EXISTS — safe to run anytime, on netlifydb.

ALTER TABLE communities ADD COLUMN IF NOT EXISTS color_primary   text NOT NULL DEFAULT '#1e3a8a';
ALTER TABLE communities ADD COLUMN IF NOT EXISTS color_secondary text NOT NULL DEFAULT '#ffffff';

CREATE TABLE IF NOT EXISTS schedule_communities (
  id serial PRIMARY KEY,
  schedule_id  integer NOT NULL REFERENCES registration_schedules(id) ON DELETE CASCADE,
  community_id integer NOT NULL REFERENCES communities(id)            ON DELETE CASCADE
);

CREATE INDEX IF NOT EXISTS idx_schedule_communities_schedule  ON schedule_communities(schedule_id);
CREATE INDEX IF NOT EXISTS idx_schedule_communities_community ON schedule_communities(community_id);

-- Prevent duplicate tags of the same community on the same schedule.
CREATE UNIQUE INDEX IF NOT EXISTS uq_schedule_community ON schedule_communities(schedule_id, community_id);
